    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@askrjs/askr-ui": ["./src/index.ts"],
      "@askrjs/askr-ui/button": ["./src/components/button/index.ts"],
      "@askrjs/askr-ui/checkbox": ["./src/components/checkbox/index.ts"],
      "@askrjs/askr-ui/focus-ring": ["./src/components/focus-ring/index.ts"],
