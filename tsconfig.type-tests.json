{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "paths": {
      "@askrjs/askr-ui": ["./src/index.ts"],
      "@askrjs/askr-ui/primitives/*": [
        "./src/components/primitives/*/index.ts"
      ],
      "@askrjs/askr-ui/composites/field/*": [
        "./src/components/composites/field/*.tsx"
      ],
      "@askrjs/askr-ui/composites/*": [
        "./src/components/composites/*/index.ts"
      ],
      "@askrjs/askr-ui/patterns/*": ["./src/components/patterns/*/index.ts"]
    }
  },
  "include": [
    "tests/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts"
  ]
}
