{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "paths": {
      "@askrjs/ui": ["./src/index.ts"],
      "@askrjs/ui/button": ["./src/components/button/index.ts"],
      "@askrjs/ui/dialog": ["./src/components/dialog/index.ts"]
    }
  },
  "include": [
    "tests/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts"
  ]
}
