        "./src/components/dismissable-layer/index.ts"
      ],
      "@askrjs/askr-ui/dialog": ["./src/components/dialog/index.ts"],
      "@askrjs/askr-ui/alert-dialog": [
        "./src/components/alert-dialog/index.ts"
      ],
      "@askrjs/askr-ui/popover": ["./src/components/popover/index.ts"],
      "@askrjs/askr-ui/tooltip": ["./src/components/tooltip/index.ts"],
      "@askrjs/askr-ui/menu": ["./src/components/menu/index.ts"],
