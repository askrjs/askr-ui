      "@askrjs/askr-ui/switch": ["./src/components/switch/index.ts"],
      "@askrjs/askr-ui/textarea": ["./src/components/textarea/index.ts"],
      "@askrjs/askr-ui/toggle": ["./src/components/toggle/index.ts"],
      "@askrjs/askr-ui/visually-hidden": [
        "./src/components/visually-hidden/index.ts"
