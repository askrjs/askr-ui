{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "paths": {
      "@askrjs/askr": ["../askr/dist/index.d.ts"],
      "@askrjs/askr/foundations": ["../askr/dist/foundations/index.d.ts"],
      "@askrjs/askr/fx": ["../askr/dist/fx/index.d.ts"],
      "@askrjs/askr/resources": ["../askr/dist/resources/index.d.ts"],
      "@askrjs/ui": ["./src/index.ts"],
      "@askrjs/ui/foundations": ["./src/foundations/index.ts"],
      "@askrjs/ui/primitives/*": [
        "./src/components/primitives/*/index.ts"
      ],
      "@askrjs/ui/composites/field/*": [
        "./src/components/composites/field/*.tsx"
      ],
      "@askrjs/ui/composites/*": [
        "./src/components/composites/*/index.ts"
      ],
      "@askrjs/ui/patterns/*": ["./src/components/patterns/*/index.ts"]
    }
  },
  "include": [
    "tests/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts"
  ]
}

