{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "moduleResolution": "bundler",
    "paths": {}
  }
}
