{
  "name": "@askrjs/ui",
  "version": "0.0.4",
  "description": "Headless askr components",
  "keywords": [
    "accessible",
    "askr",
    "components",
    "headless",
    "ui"
  ],
  "homepage": "https://github.com/askrjs/askr-ui#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-ui/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./primitives/*": {
      "types": "./dist/components/primitives/*/*.d.ts",
      "import": "./dist/components/primitives/*/*.js",
      "require": "./dist/components/primitives/*/*.cjs"
    },
    "./composites/*": {
      "types": "./dist/components/composites/*/*.d.ts",
      "import": "./dist/components/composites/*/*.js",
      "require": "./dist/components/composites/*/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "verify:foundations": "node scripts/check-foundations-contract.js",
    "test": "npm run verify:foundations && npm run test:unit && npm run test:jsdom && npm run test:browser",
    "test:browser": "vp test run --config vitest.browser.config.ts",
    "test:component": "npm run test:browser",
    "test:jsdom": "vp test run --config vitest.jsdom.config.ts",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
    "test:unit": "npm run test:types && vp test run --config vitest.node.config.ts",
    "bench": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.config.ts",
    "generate": "node scripts/generate.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@askrjs/askr": "^0.0.31",
    "@askrjs/vite": ">=0.0.2 <0.1.0",
    "@types/node": "^25.6.0",
    "axe-core": "^4.11.4",
    "cross-env": "^10.1.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tsd": "^0.33.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.30 <0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
