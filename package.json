{
  "name": "@askrjs/ui",
  "version": "0.0.1",
  "description": "Headless askr components",
  "keywords": [
    "accessible",
    "askr",
    "components",
    "headless",
    "ui"
  ],
  "homepage": "https://github.com/askrjs/askr-ui#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-ui/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./foundations": {
      "types": "./dist/foundations/index.d.ts",
      "import": "./dist/foundations/index.js",
      "require": "./dist/foundations/index.cjs"
    },
    "./primitives/*": {
      "types": "./dist/components/primitives/*/*.d.ts",
      "import": "./dist/components/primitives/*/*.js",
      "require": "./dist/components/primitives/*/*.cjs"
    },
    "./composites/field/*": {
      "types": "./dist/components/composites/field/*.d.ts",
      "import": "./dist/components/composites/field/*.js",
      "require": "./dist/components/composites/field/*.cjs"
    },
    "./composites/*": {
      "types": "./dist/components/composites/*/*.d.ts",
      "import": "./dist/components/composites/*/*.js",
      "require": "./dist/components/composites/*/*.cjs"
    },
    "./patterns/*": {
      "types": "./dist/components/patterns/*/*.d.ts",
      "import": "./dist/components/patterns/*/*.js",
      "require": "./dist/components/patterns/*/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "pack": "npm run build",
    "dev": "vp pack --watch",
    "verify:foundations": "node scripts/check-foundations-contract.js",
    "test:unit": "npm run test:types && vp test run --config vitest.node.config.ts && vp test run --config vitest.jsdom.config.ts",
    "test:component": "vp test run --config vitest.browser.config.ts",
    "test": "npm run verify:foundations && npm run test:unit && npm run test:component",
    "quality": "npm run build && npm test && npm run bench",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
    "bench": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.config.ts",
    "inventory": "node scripts/generate-inventory.js",
    "inventory:verify": "node scripts/generate-inventory.js --verify",
    "fmt": "vp fmt .",
    "lint": "vp fmt --check .",
    "generate": "node scripts/generate.js",
    "prepublishOnly": "npm run pack"
  },
  "devDependencies": {
    "@askrjs/askr": "file:../askr",
    "@askrjs/vite": "file:../askr-vite",
    "@types/node": "^25.6.0",
    "axe-core": "^4.11.3",
    "cross-env": "^10.1.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "tsd": "^0.33.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "@askrjs/askr": "0.0.1"
  },
  "peerDependenciesMeta": {
    "@askrjs/askr": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18"
  }
}
