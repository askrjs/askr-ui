  },
  "peerDependenciesMeta": {
    "@askrjs/askr": {
      "optional": false
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "dev": "vite build --watch",
    "verify:foundations": "node scripts/check-foundations-contract.js",
    "audit:theme-contract": "node scripts/audit-theme-contract.js",
    "audit:theme-contract:strict": "node scripts/audit-theme-contract.js --strict",
    "test": "npm run verify:foundations && vitest run",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
    "bench": "cross-env NODE_ENV=production vitest bench --run --reporter=default --config vitest.bench.config.ts",
    "fmt": "prettier --write .",
    "lint": "eslint src tests benches --ext .ts,.tsx"
  },
  "devDependencies": {
    "@askrjs/askr": ">=0.0.28 <1.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "axe-core": "^4.11.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsd": "^0.33.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-axe": "^0.1.0"
