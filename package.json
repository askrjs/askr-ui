{
  "name": "@askrjs/askr-ui",
  "version": "0.0.1",
  "description": "Headless askr components",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-ui.git"
  },
  "homepage": "https://github.com/askrjs/askr-ui#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-ui/issues"
  },
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "keywords": [
    "askr",
    "ui",
    "components",
    "headless",
    "accessible"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./primitives/*": {
      "types": "./dist/components/primitives/*/*.d.ts",
      "import": "./dist/components/primitives/*/*.js",
      "require": "./dist/components/primitives/*/*.cjs"
    },
    "./composites/field/*": {
      "types": "./dist/components/composites/field/*.d.ts",
      "import": "./dist/components/composites/field/*.js",
      "require": "./dist/components/composites/field/*.cjs"
    },
    "./composites/*": {
      "types": "./dist/components/composites/*/*.d.ts",
      "import": "./dist/components/composites/*/*.js",
      "require": "./dist/components/composites/*/*.cjs"
    },
    "./patterns/*": {
      "types": "./dist/components/patterns/*/*.d.ts",
      "import": "./dist/components/patterns/*/*.js",
      "require": "./dist/components/patterns/*/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@askrjs/askr": "0.0.1"
  },
  "peerDependenciesMeta": {
    "@askrjs/askr": {
      "optional": false
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:js": "vp build",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "dev": "vp build --watch",
    "verify:foundations": "node scripts/check-foundations-contract.js",
    "test": "npm run verify:foundations && vp test run",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
    "bench": "cross-env NODE_ENV=production vp test bench --run --reporter=default --config vitest.bench.config.ts",
    "fmt": "vp fmt .",
    "lint": "vp fmt --check .",
    "generate": "node scripts/generate.js"
  },
  "devDependencies": {
    "@askrjs/askr": "0.0.1",
    "@askrjs/askr-vite": "github:askrjs/askr-vite",
    "@types/node": "^25.5.0",
    "axe-core": "^4.11.2",
    "cross-env": "^10.1.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "tsd": "^0.33.0",
    "typescript": "^6.0.2",
    "vitest-axe": "^0.1.0",
    "vite-plus": "latest"
  }
}
