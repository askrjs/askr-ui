{
  "name": "@askrjs/askr-ui",
  "version": "0.0.1",
  "description": "Headless askr components",
  "type": "module",
  "packageManager": "npm@11.7.0",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:types": "npm run build && node scripts/generate-dist-test.js && tsd",
    "bench": "cross-env NODE_ENV=production vitest bench --run --reporter=default --config vitest.bench.config.ts",
    "fmt": "prettier --write .",
    "lint": "eslint src tests benches --ext .ts,.tsx"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.6",
    "axe-core": "^4.11.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "tsd": "^0.33.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@askrjs/askr": "^0.0.9"
  }
}
